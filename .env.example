# ============================
# Frontend (Vite — exposed to browser)
# ============================
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Later: when we add Apple/Instagram auth
VITE_SUPABASE_APPLE_CLIENT_ID=
VITE_SUPABASE_META_CLIENT_ID=

# ============================
# Backend (Vercel env vars — server-side only)
# ============================
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
CRON_SECRET=your-cron-secret

# ============================
# Agent Routing
# ============================
# Controls how agent tasks are executed:
#   local      → pipes through local Claude CLI (uses Pro subscription, FREE)
#   api        → calls Anthropic API directly (uses ANTHROPIC_API_KEY, PAID per-token)
#   (unset)    → simulation mode (no AI, mock responses)
#
# Use "local" when developing in the IDE.
# Use "api" on Vercel production for autonomous background tasks.
AGENT_ROUTE=local

# Only needed when AGENT_ROUTE=api (or on Vercel production)
ANTHROPIC_API_KEY=

# ============================
# Cloud Run (optional — heavier workloads)
# ============================
CLOUD_RUN_AGENT_URL=
CLOUD_RUN_AUTH_TOKEN=

# ============================
# MOSO Bridge (connects MOSO Overseer → Dashboard)
# ============================
# Shared secret for authenticating bridge syncs from Apps Script or CLI
MOSO_BRIDGE_SECRET=your-bridge-secret

# Google Sheets Personal_Log ID (for future direct read integration)
PERSONAL_LOG_SHEET_ID=1_1Ix8tTLuYnUWJdkYXjcb1Nxtqb12rIg2ueP5aH1Pug

# ============================
# Vercel Production URL (for CLI --prod flag)
# ============================
VERCEL_PROD_URL=https://labno-labs-center.vercel.app
