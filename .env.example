# ============================
# Frontend (Vite — exposed to browser)
# ============================
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Later: when we add Apple/Instagram auth
VITE_SUPABASE_APPLE_CLIENT_ID=
VITE_SUPABASE_META_CLIENT_ID=

# ============================
# Backend (Vercel env vars — server-side only)
# ============================
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
CRON_SECRET=your-cron-secret

# ============================
# AI / Agent Routing
# ============================
# Controls how agent tasks are executed:
#   local      → pipes through local Claude CLI (uses Pro subscription, FREE)
#   api        → calls Anthropic API directly (uses ANTHROPIC_API_KEY, PAID per-token)
#   (unset)    → simulation mode (no AI, mock responses)
AGENT_ROUTE=local

# Anthropic API — needed for Oracle RAG queries and agent tasks
ANTHROPIC_API_KEY=
# Secondary key for sniper agent (optional — falls back to ANTHROPIC_API_KEY)
ANTHROPIC_SNIPER_KEY=

# ============================
# Cloud Run (optional — heavier workloads)
# ============================
CLOUD_RUN_AGENT_URL=
CLOUD_RUN_AUTH_TOKEN=

# ============================
# RingCentral (click-to-call + SMS from Reactivation Inbox)
# ============================
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_JWT_TOKEN=
RINGCENTRAL_FROM_NUMBER=

# ============================
# PostHog Analytics (Telemetry page + DAU tracking)
# ============================
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.posthog.com

# ============================
# Lemon Squeezy (Revenue tracking from product sales)
# ============================
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=

# ============================
# MOSO Bridge (connects MOSO Overseer → Dashboard)
# ============================
MOSO_BRIDGE_SECRET=your-bridge-secret
PERSONAL_LOG_SHEET_ID=1_1Ix8tTLuYnUWJdkYXjcb1Nxtqb12rIg2ueP5aH1Pug

# ============================
# Vercel Production URL
# ============================
VERCEL_PROD_URL=https://labno-labs-center.vercel.app
