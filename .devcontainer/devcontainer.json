{
  "name": "Labno Labs Center",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {}
  },
  "forwardPorts": [5173, 3000],
  "postCreateCommand": "npm install && pip install -r api/requirements.txt 2>/dev/null || true",
  "postStartCommand": "npx vercel link --project labno-labs-center --scope labno-labs --yes && npx vercel env pull .env.local --yes",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "GitHub.copilot",
        "GitHub.vscode-pull-request-github",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker",
        "antfu.icons-carbon",
        "anthropics.claude-code"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "files.trimTrailingWhitespace": true,
        "terminal.integrated.defaultProfile.linux": "bash",
        "eslint.enable": true
      }
    },
    "codespaces": {
      "openFiles": ["src/pages/Dashboard.jsx", "CLAUDE.md"]
    }
  },
  "remoteEnv": {
    "AGENT_ROUTE": "local",
    "NODE_ENV": "development",
    "VERCEL_ORG_ID": "team_vLxNlKai1uZFWja56cK8LSGk",
    "VERCEL_PROJECT_ID": "prj_ExahuR571AQSQtdV2dUYYOuNCRAZ"
  },
  "containerEnv": {
    "TZ": "America/Chicago"
  },
  "mounts": [],
  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb",
    "storage": "16gb"
  }
}
