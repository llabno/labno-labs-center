{
  "framework": "vite",
  "crons": [
    {
      "path": "/api/agent/process",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/backup/export?cron=true",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/data/quality-notify",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/telemetry/aggregate",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/reactivation/score",
      "schedule": "15 6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ]
    }
  ]
}
